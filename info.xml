<?xml version="1.0"?>
<extension key="com.joineryhq.cpreports" type="module">
  <file>cpreports</file>
  <name>CarePartners Reports</name>
  <description>Custom CiviCRM reports for CarePartners</description>
  <license>GPL-3.0</license>
  <maintainer>
    <author>Allen Shaw</author>
    <email>allen@JoineryHQ.com</email>
  </maintainer>
  <urls>
    <url desc="Main Extension Page">https://github.com/twomice/com.joineryhq.cpreports</url>
    <url desc="Documentation">https://github.com/twomice/com.joineryhq.cpreports</url>
    <url desc="Support">https://joieryhq.com</url>
    <url desc="Licensing">http://www.gnu.org/licenses/gpl-3.0.html</url>
  </urls>
  <releaseDate>2022-11-07</releaseDate>
  <version>1.1.7</version>
  <develStage>beta</develStage>
  <compatibility>
    <ver>5.51</ver>
  </compatibility>
  <comments>Developed for CarePartners by Joinery.</comments>
  <civix>
    <namespace>CRM/Cpreports</namespace>
    <format>25.10.2</format>
  </civix>
  <mixins>
    <mixin>mgd-php@2.0.0</mixin>
    <mixin>smarty-v2@1.0.3</mixin>
    <mixin>scan-classes@1.0.0</mixin>
  </mixins>
  <classloader>
    <psr0 prefix="CRM_" path="."/>
    <psr4 prefix="Civi\" path="Civi"/>
  </classloader>
  <upgrader>CiviMix\Schema\Cpreports\AutomaticUpgrader</upgrader>
</extension>
